# --- Telegram (from https://my.telegram.org, YOUR OWN account) ---
TG_API_ID=
TG_API_HASH=
# Generated once via `docker compose run --rm telegram-listener python login.py`
TG_SESSION_STRING=
# Comma-separated channel usernames or numeric ids to monitor, e.g. "fieldreports,-1001234567890"
TG_CHANNELS=

# --- Storage ---
# Absolute host path for persistent data (SQLite db, incoming photos,
# enrollment photos). Leave blank for local/relative ./data (fine for
# SSH/CLI deploys). For Portainer, use docker-compose.portainer.yml instead,
# which has this hardcoded (see that file's comment for why).
DATA_DIR=

# --- Behaviour tuning ---
POLL_INTERVAL_SECONDS=60
# Cosine similarity threshold for a face to count as a match (0-1). Start at 0.45
# for insightface buffalo_s and tune after real-world testing.
MATCH_THRESHOLD=0.45
# How long sighting/photo records are kept before the retention job purges them.
RETENTION_DAYS=90

# --- Dashboard auth (LAN/VPN only — do not expose to the open internet) ---
DASHBOARD_USER=admin
# Generate with: docker compose run --rm dashboard python hash_password.py 'your-password'
DASHBOARD_PASSWORD_HASH=
